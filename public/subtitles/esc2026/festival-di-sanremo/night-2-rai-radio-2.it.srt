1055
01:03:50,560 --> 01:03:56,120
# Non lo sai neanche tu

1056
01:03:56,160 --> 01:03:59,400
# Ma di certo si può

1057
01:03:59,440 --> 01:04:02,120
# Sì, si può

1058
01:04:02,160 --> 01:04:07,080
